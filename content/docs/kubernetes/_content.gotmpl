{{/*
  Kubernetes content adapter: generates API reference pages for each
  agentgateway custom resource.

  Each page includes:
    1. The interactive kubespec HTML widget (pre-built by CI and stored in
       assets/agw-docs/pages/reference/api/{version}/).
    2. A table-style reference generated at build time from the CRD YAML
       fetched directly from GitHub.

  CONFIGURATION — edit the sections below to change sources, outputs, or targets.
  RENDERING     — the logic below the config sections should not need editing.
*/}}

{{/* =================================================================== */}}
{{/* SOURCES — where to fetch CRD YAML files                             */}}
{{/* =================================================================== */}}
{{ $crdBase := "https://raw.githubusercontent.com/agentgateway/agentgateway/refs/heads/main/controller/install/helm/agentgateway-crds/templates" }}

{{/* =================================================================== */}}
{{/* TARGETS — version prefixes to generate pages into                    */}}
{{/* =================================================================== */}}
{{ $targets := slice "latest" "main" }}

{{/* =================================================================== */}}
{{/* PAGES — CRD definition per resource                                  */}}
{{/*                                                                     */}}
{{/*   file    : CRD YAML filename fetched from $crdBase                  */}}
{{/*   htmlFile: HTML filename in assets/agw-docs/pages/reference/api/    */}}
{{/*   path    : output path under {version}/reference/api/               */}}
{{/*   title   : page title                                               */}}
{{/*   weight  : sort order                                               */}}
{{/*   desc    : page description                                         */}}
{{/* =================================================================== */}}
{{ $crdPages := slice
  (dict
    "file"     "agentgateway.dev_agentgatewaypolicies.yaml"
    "htmlFile" "agentgateway.dev_agentgatewaypolicies.yaml.html"
    "path"     "api/policies"
    "title"    "AgentgatewayPolicy"
    "weight"   1
    "desc"     "Use AgentgatewayPolicy to configure traffic manipulation, observability, security, and more."
  )
  (dict
    "file"     "agentgateway.dev_agentgatewaybackends.yaml"
    "htmlFile" "agentgateway.dev_agentgatewaybackends.yaml.html"
    "path"     "api/backends"
    "title"    "AgentgatewayBackend"
    "weight"   10
    "desc"     "Use AgentgatewayBackends to configure the target services that agentgateway routes traffic to."
  )
  (dict
    "file"     "agentgateway.dev_agentgatewayparameters.yaml"
    "htmlFile" "agentgateway.dev_agentgatewayparameters.yaml.html"
    "path"     "api/parameters"
    "title"    "AgentgatewayParameters"
    "weight"   20
    "desc"     "Use AgentgatewayParameters to configure the agentgateway data plane."
  )
}}

{{/* =================================================================== */}}
{{/* RENDERING — fetch CRDs and generate pages. No config below here.    */}}
{{/* =================================================================== */}}

{{/* --- Fetch and parse each CRD YAML once (shared across all versions) --- */}}
{{ $parsedCrds := slice }}
{{ range $crdPages }}
  {{ $url := printf "%s/%s" $crdBase .file }}
  {{ with try (resources.GetRemote $url) }}
    {{ with .Err }}
      {{ warnf "Failed to fetch CRD %s: %s" $url . }}
      {{ $parsedCrds = $parsedCrds | append (dict "ok" false) }}
    {{ else with .Value }}
      {{ $crd := .Content | transform.Unmarshal }}
      {{ $names  := $crd.spec.names }}
      {{ $ver    := index $crd.spec.versions 0 }}
      {{ $schema := $ver.schema.openAPIV3Schema }}
      {{ $parsedCrds = $parsedCrds | append (dict
        "ok"         true
        "kind"       $names.kind
        "shortNames" ($names.shortNames | default slice)
        "group"      $crd.spec.group
        "version"    $ver.name
        "schema"     $schema
      ) }}
    {{ end }}
  {{ end }}
{{ end }}

{{/* --- Helper: recursively render fields into a markdown table --- */}}
{{/* Hugo templates can't recurse natively, so we inline up to 3 levels. */}}
{{ define "renderFieldTable" }}
  {{/* params: props (dict), prefix (string) */}}
  {{ $props  := .props }}
  {{ $prefix := .prefix }}
  {{ $rows   := "" }}
  {{ range $fname, $fprop := $props }}
    {{ $fpath := $fname }}
    {{ if $prefix }}{{ $fpath = printf "%s.%s" $prefix $fname }}{{ end }}
    {{/* Determine type */}}
    {{ $ftype := "" }}
    {{ with $fprop.type }}
      {{ if reflect.IsSlice . }}
        {{ $filtered := slice }}
        {{ range . }}{{ if ne . "null" }}{{ $filtered = $filtered | append . }}{{ end }}{{ end }}
        {{ $ftype = delimit $filtered " \\| " }}
      {{ else }}
        {{ $ftype = . }}
      {{ end }}
    {{ end }}
    {{ if eq $ftype "array" }}
      {{ with $fprop.items }}
        {{ if .type }}{{ $ftype = printf "[]%s" .type }}{{ end }}
      {{ end }}
    {{ end }}
    {{ if not $ftype }}{{ $ftype = "object" }}{{ end }}
    {{/* Required indicator */}}
    {{ $req := "" }}
    {{ if $fprop.required }}{{ $req = " *" }}{{ end }}
    {{/* Description — strip newlines, escape pipes, cap length */}}
    {{ $fdesc := $fprop.description | default "" }}
    {{ $fdesc  = replace $fdesc "|" "\\|" }}
    {{ $fdesc  = replace $fdesc "\n" " " }}
    {{ if gt (len $fdesc) 300 }}{{ $fdesc = printf "%s..." (substr $fdesc 0 300) }}{{ end }}
    {{ $rows = printf "%s| `%s`%s | `%s` | %s |\n" $rows $fpath $req $ftype $fdesc }}
    {{/* One level of nested properties */}}
    {{ with $fprop.properties }}
      {{ range $subname, $subprop := . }}
        {{ $spath := printf "%s.%s" $fpath $subname }}
        {{ $stype := "" }}
        {{ with $subprop.type }}
          {{ if reflect.IsSlice . }}
            {{ $filtered := slice }}
            {{ range . }}{{ if ne . "null" }}{{ $filtered = $filtered | append . }}{{ end }}{{ end }}
            {{ $stype = delimit $filtered " \\| " }}
          {{ else }}
            {{ $stype = . }}
          {{ end }}
        {{ end }}
        {{ if eq $stype "array" }}
          {{ with $subprop.items }}{{ if .type }}{{ $stype = printf "[]%s" .type }}{{ end }}{{ end }}
        {{ end }}
        {{ if not $stype }}{{ $stype = "object" }}{{ end }}
        {{ $sdesc := $subprop.description | default "" }}
        {{ $sdesc  = replace $sdesc "|" "\\|" }}
        {{ $sdesc  = replace $sdesc "\n" " " }}
        {{ if gt (len $sdesc) 300 }}{{ $sdesc = printf "%s..." (substr $sdesc 0 300) }}{{ end }}
        {{ $rows = printf "%s| `%s` | `%s` | %s |\n" $rows $spath $stype $sdesc }}
        {{/* Two levels deep */}}
        {{ with $subprop.properties }}
          {{ range $subsubname, $subsubprop := . }}
            {{ $sspath := printf "%s.%s" $spath $subsubname }}
            {{ $sstype := $subsubprop.type | default "object" }}
            {{ if eq $sstype "array" }}
              {{ with $subsubprop.items }}{{ if .type }}{{ $sstype = printf "[]%s" .type }}{{ end }}{{ end }}
            {{ end }}
            {{ $ssdesc := $subsubprop.description | default "" }}
            {{ $ssdesc  = replace $ssdesc "|" "\\|" }}
            {{ $ssdesc  = replace $ssdesc "\n" " " }}
            {{ if gt (len $ssdesc) 300 }}{{ $ssdesc = printf "%s..." (substr $ssdesc 0 300) }}{{ end }}
            {{ $rows = printf "%s| `%s` | `%s` | %s |\n" $rows $sspath $sstype $ssdesc }}
          {{ end }}
        {{ end }}
      {{ end }}
    {{ end }}
  {{ end }}
  {{- $rows -}}
{{ end }}

{{/* --- Generate pages for each version --- */}}
{{ range $version := $targets }}
  {{ range $i, $page := $crdPages }}
    {{ $crd := index $parsedCrds $i }}

    {{/* --- Kubespec HTML widget — loaded as a page param, not inline Markdown.
         Embedding raw HTML (including <script> blocks) inside a "text/markdown"
         content string causes Goldmark to corrupt the JavaScript: blank lines
         inside <script> become <p> tags and the typographer extension HTML-encodes
         quote characters inside string literals, breaking widget initialization.
         By passing the HTML through .Params.widgetHtml and rendering it with
         safeHTML in the layout, we bypass Goldmark entirely for this section. */}}
    {{ $widgetHtml := "" }}
    {{ $htmlPath := printf "assets/agw-docs/pages/reference/api/%s/%s" $version $page.htmlFile }}
    {{ if os.FileExists $htmlPath }}
      {{ $widgetHtml = readFile $htmlPath }}
    {{ else }}
      {{ warnf "Kubespec HTML not found: %s (skipping widget section for %s %s)" $htmlPath $page.title $version }}
    {{ end }}

    {{/* --- Field reference section from CRD YAML — Markdown, safe for Goldmark.
         Structure: each top-level spec field becomes an H3 subheading; its
         nested fields (levels 1 and 2) appear in a table beneath it.
         Field names in the table use plain text (no backtick wrapping). */}}
    {{ $tableSection := "" }}
    {{ if $crd.ok }}
      {{ $schema := $crd.schema }}
      {{ $specProps := dict }}
      {{ with $schema.properties }}
        {{ with index . "spec" }}
          {{ $specProps = .properties | default dict }}
        {{ end }}
      {{ end }}

      {{ $headerMd := printf "## Spec reference\n\n" }}
      {{ with $crd.shortNames }}
        {{ $headerMd = printf "%sShort name: `%s`  \n" $headerMd (delimit . "`, `") }}
      {{ end }}
      {{ $headerMd = printf "%sAPI group: `%s/%s`\n\n" $headerMd $crd.group $crd.version }}

      {{/* ---------------------------------------------------------------- */}}
      {{/* EXAMPLE CR — skeleton YAML with placeholders, capped at 3 levels */}}
      {{/* ---------------------------------------------------------------- */}}
      {{/* Helper macro: returns the scalar placeholder for a given type/enum */}}

      {{ $exLines := slice }}
      {{ $exLines = $exLines | append (printf "apiVersion: %s/%s" $crd.group $crd.version) }}
      {{ $exLines = $exLines | append (printf "kind: %s" $crd.kind) }}
      {{ $exLines = $exLines | append "metadata:" }}
      {{ $exName := lower $crd.kind }}
      {{ with $crd.shortNames }}{{ $exName = index . 0 }}{{ end }}
      {{ $exLines = $exLines | append (printf "  name: my-%s" $exName) }}
      {{ $exLines = $exLines | append "  namespace: default" }}
      {{ $exLines = $exLines | append "spec:" }}

      {{ range $fname, $fprop := $specProps }}
        {{ $f0req  := $crd.schema.properties.spec.required | default slice }}
        {{ $f0opt  := not (in $f0req $fname) }}
        {{ $f0cmt  := cond $f0opt "  # optional" "" }}
        {{ $f0type := $fprop.type | default "object" }}
        {{ $f0enum := $fprop.enum | default slice }}

        {{ if $f0enum }}
          {{ $exLines = $exLines | append (printf "  %s: %s%s" $fname (index $f0enum 0) $f0cmt) }}
        {{ else if eq $f0type "string" }}
          {{ $exLines = $exLines | append (printf "  %s: \"\"%s" $fname $f0cmt) }}
        {{ else if eq $f0type "integer" }}
          {{ $exLines = $exLines | append (printf "  %s: 0%s" $fname $f0cmt) }}
        {{ else if eq $f0type "boolean" }}
          {{ $exLines = $exLines | append (printf "  %s: false%s" $fname $f0cmt) }}
        {{ else if eq $f0type "array" }}
          {{ $exLines = $exLines | append (printf "  %s:%s" $fname $f0cmt) }}
          {{ $f0items := $fprop.items | default dict }}
          {{ $f0itype := $f0items.type | default "object" }}
          {{ $f0iprops := $f0items.properties | default dict }}
          {{ $f0ireq   := $f0items.required | default slice }}
          {{ if $f0iprops }}
            {{ $exLines = $exLines | append "    -" }}
            {{ range $sname, $sprop := $f0iprops }}
              {{ $s1req  := in $f0ireq $sname }}
              {{ $s1cmt  := cond $s1req "" "  # optional" }}
              {{ $s1type := $sprop.type | default "object" }}
              {{ $s1enum := $sprop.enum | default slice }}
              {{ if $s1enum }}
                {{ $exLines = $exLines | append (printf "      %s: %s%s" $sname (index $s1enum 0) $s1cmt) }}
              {{ else if eq $s1type "string" }}
                {{ $exLines = $exLines | append (printf "      %s: \"\"%s" $sname $s1cmt) }}
              {{ else if eq $s1type "integer" }}
                {{ $exLines = $exLines | append (printf "      %s: 0%s" $sname $s1cmt) }}
              {{ else if eq $s1type "boolean" }}
                {{ $exLines = $exLines | append (printf "      %s: false%s" $sname $s1cmt) }}
              {{ else }}
                {{ $exLines = $exLines | append (printf "      %s: {}%s" $sname $s1cmt) }}
              {{ end }}
            {{ end }}
          {{ else if eq $f0itype "string" }}
            {{ $exLines = $exLines | append "    - \"\"" }}
          {{ else if eq $f0itype "integer" }}
            {{ $exLines = $exLines | append "    - 0" }}
          {{ else }}
            {{ $exLines = $exLines | append "    - {}" }}
          {{ end }}
        {{ else }}
          {{/* object — recurse up to 2 more levels inline */}}
          {{ $f0props := $fprop.properties | default dict }}
          {{ $f0req2  := $fprop.required | default slice }}
          {{ if $f0props }}
            {{ $exLines = $exLines | append (printf "  %s:%s" $fname $f0cmt) }}
            {{ range $sname, $sprop := $f0props }}
              {{ $s1req  := in $f0req2 $sname }}
              {{ $s1cmt  := cond $s1req "" "  # optional" }}
              {{ $s1type := $sprop.type | default "object" }}
              {{ $s1enum := $sprop.enum | default slice }}
              {{ $s1props := $sprop.properties | default dict }}
              {{ $s1req2  := $sprop.required | default slice }}
              {{ if $s1enum }}
                {{ $exLines = $exLines | append (printf "    %s: %s%s" $sname (index $s1enum 0) $s1cmt) }}
              {{ else if eq $s1type "string" }}
                {{ $exLines = $exLines | append (printf "    %s: \"\"%s" $sname $s1cmt) }}
              {{ else if eq $s1type "integer" }}
                {{ $exLines = $exLines | append (printf "    %s: 0%s" $sname $s1cmt) }}
              {{ else if eq $s1type "boolean" }}
                {{ $exLines = $exLines | append (printf "    %s: false%s" $sname $s1cmt) }}
              {{ else if eq $s1type "array" }}
                {{ $exLines = $exLines | append (printf "    %s:%s" $sname $s1cmt) }}
                {{ $s1items := $sprop.items | default dict }}
                {{ $s1itype := $s1items.type | default "object" }}
                {{ if eq $s1itype "string" }}
                  {{ $exLines = $exLines | append "      - \"\"" }}
                {{ else if eq $s1itype "integer" }}
                  {{ $exLines = $exLines | append "      - 0" }}
                {{ else }}
                  {{ $exLines = $exLines | append "      - {}" }}
                {{ end }}
              {{ else if $s1props }}
                {{ $exLines = $exLines | append (printf "    %s:%s" $sname $s1cmt) }}
                {{ range $ssname, $ssprop := $s1props }}
                  {{ $s2req  := in $s1req2 $ssname }}
                  {{ $s2cmt  := cond $s2req "" "  # optional" }}
                  {{ $s2type := $ssprop.type | default "object" }}
                  {{ $s2enum := $ssprop.enum | default slice }}
                  {{ if $s2enum }}
                    {{ $exLines = $exLines | append (printf "      %s: %s%s" $ssname (index $s2enum 0) $s2cmt) }}
                  {{ else if eq $s2type "string" }}
                    {{ $exLines = $exLines | append (printf "      %s: \"\"%s" $ssname $s2cmt) }}
                  {{ else if eq $s2type "integer" }}
                    {{ $exLines = $exLines | append (printf "      %s: 0%s" $ssname $s2cmt) }}
                  {{ else if eq $s2type "boolean" }}
                    {{ $exLines = $exLines | append (printf "      %s: false%s" $ssname $s2cmt) }}
                  {{ else }}
                    {{ $exLines = $exLines | append (printf "      %s: {}%s" $ssname $s2cmt) }}
                  {{ end }}
                {{ end }}
              {{ else }}
                {{ $exLines = $exLines | append (printf "    %s: {}%s" $sname $s1cmt) }}
              {{ end }}
            {{ end }}
          {{ else }}
            {{ $exLines = $exLines | append (printf "  %s: {}%s" $fname $f0cmt) }}
          {{ end }}
        {{ end }}
      {{ end }}

      {{ $exYaml  := delimit $exLines "\n" }}
      {{ $detailsTitle := printf "Expand for a %s example YAML" $crd.kind }}
      {{/* Goldmark does not process Markdown (fenced code blocks) inside raw HTML
           blocks, so we emit the YAML as an HTML <pre><code> element with the YAML
           content HTML-escaped. The highlight class signals Chroma; if Chroma isn't
           applied at render time the plain <pre> still renders correctly.
           {{% details %}} shortcode delimiters are not processed in content-adapter
           Markdown, so we use the Hextra details HTML directly. */}}
      {{ $exYamlHtml := $exYaml | htmlEscape }}
      {{ $exBlock := printf "### Example YAML\n\n<details class=\"hx:last-of-type:mb-0 hx:rounded-lg hx:bg-neutral-50 hx:dark:bg-neutral-800 hx:p-2 hx:mt-4 hx:group\">\n<summary class=\"hx:flex hx:items-center hx:cursor-pointer hx:select-none hx:list-none hx:p-1 hx:rounded-sm hx:transition-colors hx:hover:bg-gray-100 hx:dark:hover:bg-neutral-800 hx:before:mr-1 hx:before:inline-block hx:before:transition-transform hx:before:content-[''] hx:dark:before:invert hx:rtl:before:rotate-180 hx:group-open:before:rotate-90\"><strong class=\"hx:text-lg\">%s</strong></summary>\n<div class=\"hx:p-2 hx:overflow-auto\"><pre><code class=\"language-yaml\">%s</code></pre></div>\n</details>\n\n" $detailsTitle $exYamlHtml }}

      {{/* ---------------------------------------------------------------- */}}
      {{/* PER-FIELD H3 SECTIONS WITH NESTED FIELD TABLE                    */}}
      {{/* ---------------------------------------------------------------- */}}
      {{ $sections := "" }}
      {{ if $specProps }}
        {{ range $fname, $fprop := $specProps }}
          {{/* Each top-level spec field is an H3 subheading */}}
          {{ $fdesc := $fprop.description | default "" }}
          {{ $fdesc  = replace $fdesc "|" "\\|" }}
          {{ $fdesc  = replace $fdesc "\n" " " }}
          {{ $sections = printf "%s### %s\n\n" $sections $fname }}
          {{ if $fdesc }}{{ $sections = printf "%s%s\n\n" $sections $fdesc }}{{ end }}

          {{/* Nested fields go into a table under the H3.
               Paths are relative to spec.<fname> — the H3 heading provides that context. */}}
          {{ $rows := "" }}
          {{ with $fprop.properties }}
            {{ range $subname, $subprop := . }}
              {{ $stype := "" }}
              {{ with $subprop.type }}
                {{ if reflect.IsSlice . }}
                  {{ $filtered := slice }}
                  {{ range . }}{{ if ne . "null" }}{{ $filtered = $filtered | append . }}{{ end }}{{ end }}
                  {{ $stype = delimit $filtered " \\| " }}
                {{ else }}{{ $stype = . }}{{ end }}
              {{ end }}
              {{ if eq $stype "array" }}
                {{ with $subprop.items }}{{ if .type }}{{ $stype = printf "[]%s" .type }}{{ end }}{{ end }}
              {{ end }}
              {{ if not $stype }}{{ $stype = "object" }}{{ end }}
              {{ $sdesc := $subprop.description | default "" }}
              {{ $sdesc  = replace $sdesc "|" "\\|" }}
              {{ $sdesc  = replace $sdesc "\n" " " }}
              {{ if gt (len $sdesc) 300 }}{{ $sdesc = printf "%s..." (substr $sdesc 0 300) }}{{ end }}
              {{ $rows = printf "%s| %s | `%s` | %s |\n" $rows $subname $stype $sdesc }}
              {{/* Level 2 nested fields — relative to spec.<fname>.<subname> */}}
              {{ with $subprop.properties }}
                {{ range $ssname, $ssprop := . }}
                  {{ $sstype := "" }}
                  {{ with $ssprop.type }}
                    {{ if reflect.IsSlice . }}
                      {{ $filtered := slice }}
                      {{ range . }}{{ if ne . "null" }}{{ $filtered = $filtered | append . }}{{ end }}{{ end }}
                      {{ $sstype = delimit $filtered " \\| " }}
                    {{ else }}{{ $sstype = . }}{{ end }}
                  {{ end }}
                  {{ if eq $sstype "array" }}
                    {{ with $ssprop.items }}{{ if .type }}{{ $sstype = printf "[]%s" .type }}{{ end }}{{ end }}
                  {{ end }}
                  {{ if not $sstype }}{{ $sstype = "object" }}{{ end }}
                  {{ $ssdesc := $ssprop.description | default "" }}
                  {{ $ssdesc  = replace $ssdesc "|" "\\|" }}
                  {{ $ssdesc  = replace $ssdesc "\n" " " }}
                  {{ if gt (len $ssdesc) 300 }}{{ $ssdesc = printf "%s..." (substr $ssdesc 0 300) }}{{ end }}
                  {{ $rows = printf "%s| %s.%s | `%s` | %s |\n" $rows $subname $ssname $sstype $ssdesc }}
                {{ end }}
              {{ end }}
            {{ end }}
          {{ end }}
          {{ if $rows }}
            {{ $sections = printf "%s| Field | Type | Description |\n|-------|------|-------------|\n%s\n" $sections $rows }}
          {{ end }}
        {{ end }}
        {{ $tableSection = printf "%s%s%s" $headerMd $exBlock $sections }}
      {{ else }}
        {{ $tableSection = printf "%s_No spec fields found in CRD schema._\n" $headerMd }}
      {{ end }}
    {{ else }}
      {{ $tableSection = "_Table reference unavailable: CRD YAML could not be fetched at build time._\n" }}
    {{ end }}

    {{/* Prepend the "Interactive reference" heading + widget slot sentinel so the
         TOC partial (which scans .Content) finds both H2s, and the layout can
         split .Content at the sentinel to inject the kubespec widget HTML between
         the two sections without passing it through Goldmark. */}}
    {{ $mdContent := printf "## Interactive reference\n\n{{< reuse \"agw-docs/snippets/kubespec-note.md\" >}}\n\n<div id=\"ks-widget-slot\"></div>\n\n<div class=\"api-ref-table\">\n\n%s\n\n</div>" $tableSection }}

    {{/* --- Add page: widgetHtml in params (safeHTML in layout), Markdown in content. --- */}}
    {{ $.AddPage (dict
      "content"      (dict "mediaType" "text/markdown" "value" $mdContent)
      "kind"         "page"
      "layout"       "api-ref"
      "params"       (dict "generated" true "widgetHtml" $widgetHtml)
      "path"         (printf "%s/reference/%s" $version $page.path)
      "title"        $page.title
      "description"  $page.desc
      "weight"       $page.weight
    ) }}
  {{ end }}
{{ end }}
