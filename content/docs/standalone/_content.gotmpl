{{/*
  Standalone content adapter: generates configuration reference pages
  from the agentgateway JSON schema + CEL schema, fetched from GitHub.
  Also generates an interactive CEL context widget page (pre-built HTML from CI)
  stored in assets/agw-docs/pages/reference/cel/{version}/.

  CONFIGURATION — edit the sections below to change sources, outputs, or targets.
  RENDERING     — the logic below the config sections should not need editing.
*/}}

{{/* =================================================================== */}}
{{/* SOURCES — where to fetch structured data                            */}}
{{/*                                                                     */}}
{{/* YAML path hints for each $defs type live in data/schema_config_paths */}}
{{/* (pathsByDef). Regenerate with: python3 scripts/gen-schema-config-paths.py */}}
{{/* =================================================================== */}}
{{ $sources := dict
  "configSchema" "https://raw.githubusercontent.com/agentgateway/agentgateway/refs/heads/main/schema/config.json"
  "celSchema"    "https://raw.githubusercontent.com/agentgateway/agentgateway/refs/heads/main/schema/cel.json"
}}

{{/* =================================================================== */}}
{{/* TARGETS — version prefixes to generate pages into                    */}}
{{/* =================================================================== */}}
{{ $targets := slice "latest/reference" "main/reference" }}

{{/* =================================================================== */}}
{{/* PAGES — source type → output path, one line per generated page      */}}
{{/*                                                                     */}}
{{/*   defName : key in the config schema's _defs (source)               */}}
{{/*   path    : output path under each target prefix                    */}}
{{/*   title   : page title in nav                                       */}}
{{/*   weight  : sort order in nav                                       */}}
{{/*   desc    : intro text on the page                                  */}}
{{/*                                                                     */}}
{{/* These entries drive the per-section table content of the full-schema */}}
{{/* page only. The per-section index page and per-section subpages have  */}}
{{/* been removed (we publish a single combined schema reference plus the */}}
{{/* manually-authored validation guide).                                 */}}
{{/* =================================================================== */}}
{{ $configPages := slice
  (dict "defName" "RawConfig"              "title" "Global Config"          "desc" "Top-level settings for DNS, admin, networking, observability, and session management.")
  (dict "defName" "LocalBind"              "title" "Binds & Listeners"      "desc" "Configure ports, listeners, hostnames, TLS, and routing.")
  (dict "defName" "LocalListener"          "title" "Listener"               "desc" "Configure a listener within a bind, including hostname, protocol, TLS, and routes.")
  (dict "defName" "LocalRoute"             "title" "Route"                  "desc" "Define an HTTP route with matching rules, backends, and inline policies.")
  (dict "defName" "FullLocalBackend"       "title" "Backends"               "desc" "Define backend targets including AI providers, static hosts, and load balancing.")
  (dict "defName" "LocalBackendTLS"        "title" "Backend TLS"            "desc" "TLS settings for backend connections.")
  (dict "defName" "LocalPolicy"            "title" "Policies"               "desc" "Attach reusable policies for authentication, rate limiting, authorization, and more.")
  (dict "defName" "FilterOrPolicy"         "title" "Policy & Filter Fields" "desc" "All available policy and filter fields that can be used inline on routes, listeners, gateways, and backends.")
  (dict "defName" "CorsSerde"              "title" "CORS"                   "desc" "Cross-Origin Resource Sharing (CORS) policy configuration.")
  (dict "defName" "RateLimitSpec"          "title" "Rate Limiting"          "desc" "Rate limit configuration for controlling request throughput.")
  (dict "defName" "LocalOidcConfig"        "title" "OIDC Authentication"    "desc" "Browser-based OIDC authentication policy using authorization code flow.")
  (dict "defName" "LocalFrontendPolicies"  "title" "Frontend Policies"      "desc" "Gateway-wide policies applied to all incoming traffic.")
  (dict "defName" "LocalLLMConfig"         "title" "LLM Gateway"            "desc" "Configure the LLM gateway with models, providers, and prompt guards.")
  (dict "defName" "LocalLLMModels"         "title" "LLM Models"             "desc" "Configure an LLM model with provider, prompt guards, and caching.")
  (dict "defName" "LocalLLMParams"         "title" "LLM Parameters"         "desc" "Parameters for LLM model routing, failover, and spending limits.")
  (dict "defName" "LocalSimpleMcpConfig"   "title" "MCP Gateway"            "desc" "Configure the MCP gateway with targets, authentication, and fan-out behavior.")
  (dict "defName" "LocalMcpBackend"        "title" "MCP Backend"            "desc" "Configure an MCP backend target with transport and authentication.")
  (dict "defName" "LocalMcpAuthentication" "title" "MCP Authentication"     "desc" "Authentication settings for MCP clients using OAuth/OIDC.")
  (dict "defName" "TracingConfig"          "title" "Tracing"                "desc" "Configuration for distributed tracing with OpenTelemetry.")
}}

{{/* =================================================================== */}}
{{/* RENDERING — fetch data, generate pages. No config below this line.  */}}
{{/* =================================================================== */}}

{{/* --- Fetch and parse config schema --- */}}
{{ $configRaw := "" }}
{{ with try (resources.GetRemote (index $sources "configSchema")) }}
  {{ with .Err }}
    {{ errorf "Failed to fetch config schema: %s" . }}
  {{ else with .Value }}
    {{ $configRaw = .Content | replaceRE `"\$ref"` `"_ref"` | replaceRE `"\$defs"` `"_defs"` | replaceRE `#/\$defs/` `#/_defs/` }}
  {{ end }}
{{ end }}
{{ $schema := $configRaw | transform.Unmarshal }}
{{ $defs := index $schema "_defs" }}

{{/* --- Fetch and parse CEL schema --- */}}
{{ $celRaw := "" }}
{{ with try (resources.GetRemote (index $sources "celSchema")) }}
  {{ with .Err }}
    {{ errorf "Failed to fetch CEL schema: %s" . }}
  {{ else with .Value }}
    {{ $celRaw = .Content }}
  {{ end }}
{{ end }}
{{ $celSchema := $celRaw | transform.Unmarshal }}

{{/* --- Generate pages for each target --- */}}
{{ range $prefix := $targets }}

  {{/* --- Config schema: full single page ---
       Lives at reference/configuration/schema, alongside the manually
       authored validation guide at reference/configuration/validation. */}}
  {{ $fullMd := "Generated from the [agentgateway JSON schema](https://github.com/agentgateway/agentgateway/blob/main/schema/config.json).\n" }}
  {{ range $configPages }}
    {{ $typeDef := index $defs .defName }}
    {{ $fullMd = printf "%s\n---\n\n## %s\n" $fullMd .title }}
    {{ with .desc }}{{ $fullMd = printf "%s\n%s\n" $fullMd . }}{{ end }}
    {{ $fullMd = printf "%s\nSchema type: `%s`\n" $fullMd .defName }}
    {{ $scp := index site.Data "schema_config_paths" | default dict }}
    {{ $pathsByDef := index $scp "pathsByDef" | default dict }}
    {{ $cfgPaths := index $pathsByDef .defName | default slice }}
    {{ if gt (len $cfgPaths) 0 }}
      {{ $fullMd = printf "%s\n%s can be configured in the following sections:\n\n```text\n%s\n```\n\n" $fullMd .title (delimit $cfgPaths "\n") }}
    {{ end }}
    {{ with $typeDef }}
      {{ with .description }}
        {{ $fullMd = printf "%s\n> %s\n" $fullMd (replace . "\n" " ") }}
      {{ end }}
      {{ with .properties }}
        {{ $fullMd = printf "%s\nYou can configure the following fields:\n\n" $fullMd }}
        {{ $fullMd = printf "%s\n| Field | Type | Description |\n|-------|------|-------------|\n" $fullMd }}
        {{ range $fname, $fprop := . }}
          {{ $ftype := "" }}
          {{ with $fprop.type }}
            {{ if reflect.IsSlice . }}
              {{ $filtered := slice }}
              {{ range . }}{{ if ne . "null" }}{{ $filtered = $filtered | append . }}{{ end }}{{ end }}
              {{ $ftype = delimit $filtered ", " }}
            {{ else }}{{ $ftype = . }}{{ end }}
          {{ end }}
          {{ if isset $fprop "_ref" }}{{ $ftype = printf "`%s`" (path.Base (index $fprop "_ref")) }}{{ end }}
          {{ with $fprop.items }}{{ if isset . "_ref" }}{{ $ftype = printf "array of `%s`" (path.Base (index . "_ref")) }}{{ end }}{{ end }}
          {{ with $fprop.anyOf }}{{ range . }}{{ if isset . "_ref" }}{{ $ftype = printf "`%s`" (path.Base (index . "_ref")) }}{{ end }}{{ end }}{{ end }}
          {{ if not $ftype }}{{ $ftype = "object" }}{{ end }}
          {{ $fdesc := $fprop.description | default "" }}
          {{ $fdesc = replace $fdesc "|" "\\|" }}
          {{ $fdesc = replace $fdesc "\n" " " }}
          {{ if gt (len $fdesc) 200 }}{{ $fdesc = printf "%s..." (substr $fdesc 0 200) }}{{ end }}
          {{ $fdefault := "" }}
          {{ if isset $fprop "default" }}{{ with $fprop.default }}{{ $fdefault = printf " Default: `%v`." . }}{{ end }}{{ end }}
          {{ $fullMd = printf "%s| `%s` | %s | %s%s |\n" $fullMd $fname $ftype $fdesc $fdefault }}
        {{ end }}
      {{ end }}
    {{ end }}
  {{ end }}
  {{ $.AddPage (dict
    "content" (dict "mediaType" "text/markdown" "value" $fullMd)
    "kind" "page"
    "params" (dict "generated" true)
    "path" (printf "%s/configuration/schema" $prefix)
    "title" "Configuration schema"
    "description" "Configuration reference for agentgateway configuration schema."
    "weight" 2
  ) }}

  {{/* --- CEL context page ---
       Lives at reference/cel/cel-context, alongside the manually authored
       playground / yaml-and-examples / variables pages. The variables page
       links here for the full table of CEL context fields. */}}
  {{ with $celSchema }}
    {{ $md := "" }}
    {{ range $name, $prop := .properties }}
      {{ $md = printf "%s\n## `%s`\n" $md $name }}
      {{ with $prop.description }}{{ $md = printf "%s\n%s\n" $md . }}{{ end }}
      {{ with $prop.properties }}
        {{ $md = printf "%s\n| Field | Type | Default | Description |\n|-------|------|---------|-------------|\n" $md }}
        {{ range $fname, $fprop := . }}
          {{ $ftype := "" }}
          {{ with $fprop.type }}
            {{ if reflect.IsSlice . }}
              {{ $filtered := slice }}
              {{ range . }}{{ if ne . "null" }}{{ $filtered = $filtered | append . }}{{ end }}{{ end }}
              {{ $ftype = delimit $filtered ", " }}
            {{ else }}{{ $ftype = . }}{{ end }}
          {{ end }}
          {{ if not $ftype }}{{ $ftype = "object" }}{{ end }}
          {{ $fdefault := "" }}
          {{ if isset $fprop "default" }}{{ with $fprop.default }}{{ $fdefault = printf "`%v`" . }}{{ end }}{{ end }}
          {{ $fdesc := $fprop.description | default "" }}
          {{ $fdesc = replace $fdesc "|" "\\|" }}
          {{ $fdesc = replace $fdesc "\n" " " }}
          {{ $md = printf "%s| `%s` | %s | %s | %s |\n" $md $fname $ftype $fdefault $fdesc }}
        {{ end }}
      {{ end }}
    {{ end }}
    {{ $.AddPage (dict
      "content" (dict "mediaType" "text/markdown" "value" $md)
      "kind" "page"
      "params" (dict "schemaType" "CEL" "generated" true)
      "path" (printf "%s/cel/cel-context" $prefix)
      "title" "CEL reference"
      "description" "The CEL expression context provides the following objects, which you can use in CEL expressions throughout agentgateway configuration."
      "weight" 4
    ) }}
  {{ end }}

  {{/* --- CEL interactive widget page ---
       Sister page to cel/cel-context; renders the pre-built HTML widget from CI.
       The HTML is generated by scripts/kubespec-render/render.go from schema/cel.json
       and stored at assets/agw-docs/pages/reference/cel/{version}/cel-context.html. */}}
  {{ $celVersion := index (split $prefix "/") 0 }}
  {{ $celWidgetHtml := "" }}
  {{ $celHtmlPath := printf "assets/agw-docs/pages/reference/cel/%s/cel-context.html" $celVersion }}
  {{ if os.FileExists $celHtmlPath }}
    {{ $celWidgetHtml = readFile $celHtmlPath }}
  {{ else }}
    {{ warnf "CEL widget HTML not found: %s (skipping interactive CEL widget for %s)" $celHtmlPath $prefix }}
  {{ end }}
  {{ $.AddPage (dict
    "content"     (dict "mediaType" "text/markdown" "value" "<p></p><div id=\"ks-widget-slot\"></div>")
    "kind"        "page"
    "layout"      "api-ref"
    "params"      (dict "generated" true "widgetHtml" $celWidgetHtml)
    "path"        (printf "%s/cel/cel-context-interactive" $prefix)
    "title"       "Interactive CEL reference"
    "description" "Explore the CEL expression context interactively, including all available variables and their nested fields."
    "weight"      5
  ) }}

{{ end }}
