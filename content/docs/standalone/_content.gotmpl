{{/*
  Standalone content adapter: generates configuration reference pages
  from the agentgateway JSON schema + CEL schema, fetched from GitHub.

  CONFIGURATION — edit the sections below to change sources, outputs, or targets.
  RENDERING     — the logic below the config sections should not need editing.
*/}}

{{/* =================================================================== */}}
{{/* SOURCES — where to fetch structured data                            */}}
{{/* =================================================================== */}}
{{ $sources := dict
  "configSchema" "https://raw.githubusercontent.com/agentgateway/agentgateway/refs/heads/main/schema/config.json"
  "celSchema"    "https://raw.githubusercontent.com/agentgateway/agentgateway/refs/heads/main/schema/cel.json"
}}

{{/* =================================================================== */}}
{{/* TARGETS — version prefixes to generate pages into                    */}}
{{/* =================================================================== */}}
{{ $targets := slice "latest/reference" "main/reference" }}

{{/* =================================================================== */}}
{{/* PAGES — source type → output path, one line per generated page      */}}
{{/*                                                                     */}}
{{/*   defName : key in the config schema's _defs (source)               */}}
{{/*   path    : output path under each target prefix                    */}}
{{/*   title   : page title in nav                                       */}}
{{/*   weight  : sort order in nav                                       */}}
{{/*   desc    : intro text on the page                                  */}}
{{/* =================================================================== */}}
{{ $configPages := slice
  (dict "defName" "RawConfig"              "path" "by-section/config"           "title" "Global Config"          "weight" 10 "desc" "Top-level settings for DNS, admin, networking, observability, and session management.")
  (dict "defName" "LocalBind"              "path" "by-section/binds"            "title" "Binds & Listeners"      "weight" 20 "desc" "Configure ports, listeners, hostnames, TLS, and routing.")
  (dict "defName" "LocalListener"          "path" "by-section/locallistener"    "title" "Listener"               "weight" 21 "desc" "Configure a listener within a bind, including hostname, protocol, TLS, and routes.")
  (dict "defName" "LocalRoute"             "path" "by-section/localroute"       "title" "Route"                  "weight" 22 "desc" "Define an HTTP route with matching rules, backends, and inline policies.")
  (dict "defName" "FullLocalBackend"       "path" "by-section/backends"         "title" "Backends"               "weight" 30 "desc" "Define backend targets including AI providers, static hosts, and load balancing.")
  (dict "defName" "LocalBackendTLS"        "path" "by-section/localbackendtls"  "title" "Backend TLS"            "weight" 31 "desc" "TLS settings for backend connections.")
  (dict "defName" "LocalPolicy"            "path" "by-section/policies"         "title" "Policies"               "weight" 40 "desc" "Attach reusable policies for authentication, rate limiting, authorization, and more.")
  (dict "defName" "FilterOrPolicy"         "path" "by-section/policyfields"     "title" "Policy & Filter Fields"  "weight" 45 "desc" "All available policy and filter fields that can be used inline on routes, listeners, gateways, and backends.")
  (dict "defName" "CorsSerde"              "path" "by-section/corsserde"        "title" "CORS"                   "weight" 46 "desc" "Cross-Origin Resource Sharing (CORS) policy configuration.")
  (dict "defName" "RateLimitSpec"          "path" "by-section/ratelimitspec"    "title" "Rate Limiting"           "weight" 47 "desc" "Rate limit configuration for controlling request throughput.")
  (dict "defName" "LocalOidcConfig"        "path" "by-section/localoidcconfig"  "title" "OIDC Authentication"     "weight" 48 "desc" "Browser-based OIDC authentication policy using authorization code flow.")
  (dict "defName" "LocalFrontendPolicies"  "path" "by-section/frontendpolicies" "title" "Frontend Policies"       "weight" 50 "desc" "Gateway-wide policies applied to all incoming traffic.")
  (dict "defName" "LocalLLMConfig"         "path" "by-section/llm"              "title" "LLM Gateway"             "weight" 60 "desc" "Configure the LLM gateway with models, providers, and prompt guards.")
  (dict "defName" "LocalLLMModels"         "path" "by-section/localllmmodels"   "title" "LLM Models"              "weight" 61 "desc" "Configure an LLM model with provider, prompt guards, and caching.")
  (dict "defName" "LocalLLMParams"         "path" "by-section/localllmparams"   "title" "LLM Parameters"          "weight" 62 "desc" "Parameters for LLM model routing, failover, and spending limits.")
  (dict "defName" "LocalSimpleMcpConfig"   "path" "by-section/mcp"              "title" "MCP Gateway"             "weight" 70 "desc" "Configure the MCP gateway with targets, authentication, and fan-out behavior.")
  (dict "defName" "LocalMcpBackend"        "path" "by-section/localmcpbackend"  "title" "MCP Backend"             "weight" 71 "desc" "Configure an MCP backend target with transport and authentication.")
  (dict "defName" "LocalMcpAuthentication" "path" "by-section/localmcpauth"     "title" "MCP Authentication"      "weight" 72 "desc" "Authentication settings for MCP clients using OAuth/OIDC.")
  (dict "defName" "TracingConfig"          "path" "by-section/tracingconfig"    "title" "Tracing"                 "weight" 81 "desc" "Configuration for distributed tracing with OpenTelemetry.")
}}

{{/* =================================================================== */}}
{{/* RENDERING — fetch data, generate pages. No config below this line.  */}}
{{/* =================================================================== */}}

{{/* --- Fetch and parse config schema --- */}}
{{ $configRaw := "" }}
{{ with try (resources.GetRemote (index $sources "configSchema")) }}
  {{ with .Err }}
    {{ errorf "Failed to fetch config schema: %s" . }}
  {{ else with .Value }}
    {{ $configRaw = .Content | replaceRE `"\$ref"` `"_ref"` | replaceRE `"\$defs"` `"_defs"` | replaceRE `#/\$defs/` `#/_defs/` }}
  {{ end }}
{{ end }}
{{ $schema := $configRaw | transform.Unmarshal }}
{{ $defs := index $schema "_defs" }}

{{/* --- Fetch and parse CEL schema --- */}}
{{ $celRaw := "" }}
{{ with try (resources.GetRemote (index $sources "celSchema")) }}
  {{ with .Err }}
    {{ errorf "Failed to fetch CEL schema: %s" . }}
  {{ else with .Value }}
    {{ $celRaw = .Content }}
  {{ end }}
{{ end }}
{{ $celSchema := $celRaw | transform.Unmarshal }}

{{/* --- Generate pages for each target --- */}}
{{ range $prefix := $targets }}

  {{/* --- By-section index page with cards --- */}}
  {{ $indexMd := "<p class=\"hx:mb-6\">Browse the configuration reference by section.</p>\n\n" }}
  {{ $indexMd = printf "%s<div class=\"hextra-cards hx:mt-4 hx:gap-4 hx:grid not-prose\" style=\"--hextra-cards-grid-cols: 3;\">\n" $indexMd }}
  {{ range $configPages }}
    {{ $slug := .path | path.Base }}
    {{ $indexMd = printf "%s<a class=\"hextra-card hx:group hx:flex hx:flex-col hx:justify-start hx:overflow-hidden hx:rounded-lg hx:border hx:border-gray-200 hx:text-current hx:no-underline hx:dark:shadow-none hx:hover:border-gray-300 hx:bg-transparent hx:shadow-xs hx:dark:border-neutral-800 hx:hover:bg-slate-50 hx:hover:shadow-md hx:dark:hover:border-neutral-700 hx:dark:hover:bg-neutral-900 hx:transition-all hx:duration-200\" href=\"%s/\">" $indexMd $slug }}
    {{ $indexMd = printf "%s<div class=\"hx:mt-auto\"><span class=\"hextra-card-icon hx:flex hx:font-semibold hx:items-start hx:gap-2 hx:p-4 hx:text-gray-700 hx:hover:text-gray-900 hx:dark:text-neutral-200 hx:dark:hover:text-neutral-50\">%s</span>" $indexMd .title }}
    {{ $indexMd = printf "%s<div class=\"hextra-card-subtitle hx:line-clamp-3 hx:text-sm hx:font-normal hx:text-gray-500 hx:dark:text-gray-400 hx:px-4 hx:mb-4 hx:mt-2\">%s</div></div></a>\n" $indexMd .desc }}
  {{ end }}
  {{ $indexMd = printf "%s</div>\n" $indexMd }}
  {{ $.AddPage (dict
    "content" (dict "mediaType" "text/html" "value" $indexMd)
    "kind" "section"
    "params" (dict "generated" true)
    "path" (printf "%s/by-section" $prefix)
    "title" "Configuration schema (by section)"
    "weight" 2
  ) }}

  {{/* --- Config schema: by-section pages --- */}}
  {{ range $configPages }}
    {{ $typeDef := index $defs .defName }}
    {{ $md := "" }}
    {{ with .desc }}
      {{ $md = printf "%s%s\n" $md . }}
    {{ end }}
    {{ $md = printf "%s\nSchema type: `%s`\n" $md .defName }}
    {{ with $typeDef }}
      {{ with .description }}
        {{ $md = printf "%s\n> %s\n" $md (replace . "\n" " ") }}
      {{ end }}
      {{ with .properties }}
        {{ $md = printf "%s\n## Fields\n\n| Field | Type | Description |\n|-------|------|-------------|\n" $md }}
        {{ range $fname, $fprop := . }}
          {{ $ftype := "" }}
          {{ with $fprop.type }}
            {{ if reflect.IsSlice . }}
              {{ $filtered := slice }}
              {{ range . }}{{ if ne . "null" }}{{ $filtered = $filtered | append . }}{{ end }}{{ end }}
              {{ $ftype = delimit $filtered ", " }}
            {{ else }}
              {{ $ftype = . }}
            {{ end }}
          {{ end }}
          {{ if isset $fprop "_ref" }}
            {{ $ftype = printf "`%s`" (path.Base (index $fprop "_ref")) }}
          {{ end }}
          {{ with $fprop.items }}
            {{ if isset . "_ref" }}
              {{ $ftype = printf "array of `%s`" (path.Base (index . "_ref")) }}
            {{ end }}
          {{ end }}
          {{ with $fprop.anyOf }}
            {{ range . }}
              {{ if isset . "_ref" }}
                {{ $ftype = printf "`%s`" (path.Base (index . "_ref")) }}
              {{ end }}
            {{ end }}
          {{ end }}
          {{ if not $ftype }}{{ $ftype = "object" }}{{ end }}
          {{ $fdesc := $fprop.description | default "" }}
          {{ $fdesc = replace $fdesc "|" "\\|" }}
          {{ $fdesc = replace $fdesc "\n" " " }}
          {{ if gt (len $fdesc) 200 }}
            {{ $fdesc = printf "%s..." (substr $fdesc 0 200) }}
          {{ end }}
          {{ $fdefault := "" }}
          {{ if isset $fprop "default" }}
            {{ with $fprop.default }}{{ $fdefault = printf " Default: `%v`." . }}{{ end }}
          {{ end }}
          {{ $md = printf "%s| `%s` | %s | %s%s |\n" $md $fname $ftype $fdesc $fdefault }}
        {{ end }}
      {{ end }}
      {{ with .oneOf }}
        {{ $md = printf "%s\n## Allowed values\n\n" $md }}
        {{ range . }}
          {{ with .description }}{{ $md = printf "%s- %s\n" $md . }}{{ else }}{{ with .const }}{{ $md = printf "%s- `%v`\n" $md . }}{{ end }}{{ end }}
        {{ end }}
      {{ end }}
    {{ end }}
    {{ $.AddPage (dict
      "content" (dict "mediaType" "text/markdown" "value" $md)
      "kind" "page"
      "params" (dict "schemaType" .defName "generated" true)
      "path" (printf "%s/%s" $prefix .path)
      "title" .title
      "weight" .weight
    ) }}
  {{ end }}

  {{/* --- Config schema: full single page --- */}}
  {{ $fullMd := "Complete configuration reference generated from the agentgateway JSON schema. All types on one page.\n" }}
  {{ range $configPages }}
    {{ $typeDef := index $defs .defName }}
    {{ $fullMd = printf "%s\n---\n\n## %s\n" $fullMd .title }}
    {{ with .desc }}{{ $fullMd = printf "%s\n%s\n" $fullMd . }}{{ end }}
    {{ $fullMd = printf "%s\nSchema type: `%s`\n" $fullMd .defName }}
    {{ with $typeDef }}
      {{ with .description }}
        {{ $fullMd = printf "%s\n> %s\n" $fullMd (replace . "\n" " ") }}
      {{ end }}
      {{ with .properties }}
        {{ $fullMd = printf "%s\n| Field | Type | Description |\n|-------|------|-------------|\n" $fullMd }}
        {{ range $fname, $fprop := . }}
          {{ $ftype := "" }}
          {{ with $fprop.type }}
            {{ if reflect.IsSlice . }}
              {{ $filtered := slice }}
              {{ range . }}{{ if ne . "null" }}{{ $filtered = $filtered | append . }}{{ end }}{{ end }}
              {{ $ftype = delimit $filtered ", " }}
            {{ else }}{{ $ftype = . }}{{ end }}
          {{ end }}
          {{ if isset $fprop "_ref" }}{{ $ftype = printf "`%s`" (path.Base (index $fprop "_ref")) }}{{ end }}
          {{ with $fprop.items }}{{ if isset . "_ref" }}{{ $ftype = printf "array of `%s`" (path.Base (index . "_ref")) }}{{ end }}{{ end }}
          {{ with $fprop.anyOf }}{{ range . }}{{ if isset . "_ref" }}{{ $ftype = printf "`%s`" (path.Base (index . "_ref")) }}{{ end }}{{ end }}{{ end }}
          {{ if not $ftype }}{{ $ftype = "object" }}{{ end }}
          {{ $fdesc := $fprop.description | default "" }}
          {{ $fdesc = replace $fdesc "|" "\\|" }}
          {{ $fdesc = replace $fdesc "\n" " " }}
          {{ if gt (len $fdesc) 200 }}{{ $fdesc = printf "%s..." (substr $fdesc 0 200) }}{{ end }}
          {{ $fdefault := "" }}
          {{ if isset $fprop "default" }}{{ with $fprop.default }}{{ $fdefault = printf " Default: `%v`." . }}{{ end }}{{ end }}
          {{ $fullMd = printf "%s| `%s` | %s | %s%s |\n" $fullMd $fname $ftype $fdesc $fdefault }}
        {{ end }}
      {{ end }}
    {{ end }}
  {{ end }}
  {{ $.AddPage (dict
    "content" (dict "mediaType" "text/markdown" "value" $fullMd)
    "kind" "page"
    "params" (dict "generated" true)
    "path" (printf "%s/full-schema" $prefix)
    "title" "Configuration schema (full page)"
    "weight" 1
  ) }}

  {{/* --- CEL context page --- */}}
  {{ with $celSchema }}
    {{ $md := "The CEL expression context provides the following objects, which you can use in CEL expressions throughout agentgateway configuration.\n" }}
    {{ range $name, $prop := .properties }}
      {{ $md = printf "%s\n## `%s`\n" $md $name }}
      {{ with $prop.description }}{{ $md = printf "%s\n%s\n" $md . }}{{ end }}
      {{ with $prop.properties }}
        {{ $md = printf "%s\n| Field | Type | Default | Description |\n|-------|------|---------|-------------|\n" $md }}
        {{ range $fname, $fprop := . }}
          {{ $ftype := "" }}
          {{ with $fprop.type }}
            {{ if reflect.IsSlice . }}
              {{ $filtered := slice }}
              {{ range . }}{{ if ne . "null" }}{{ $filtered = $filtered | append . }}{{ end }}{{ end }}
              {{ $ftype = delimit $filtered ", " }}
            {{ else }}{{ $ftype = . }}{{ end }}
          {{ end }}
          {{ if not $ftype }}{{ $ftype = "object" }}{{ end }}
          {{ $fdefault := "" }}
          {{ if isset $fprop "default" }}{{ with $fprop.default }}{{ $fdefault = printf "`%v`" . }}{{ end }}{{ end }}
          {{ $fdesc := $fprop.description | default "" }}
          {{ $fdesc = replace $fdesc "|" "\\|" }}
          {{ $fdesc = replace $fdesc "\n" " " }}
          {{ $md = printf "%s| `%s` | %s | %s | %s |\n" $md $fname $ftype $fdefault $fdesc }}
        {{ end }}
      {{ end }}
    {{ end }}
    {{ $.AddPage (dict
      "content" (dict "mediaType" "text/markdown" "value" $md)
      "kind" "page"
      "params" (dict "schemaType" "CEL" "generated" true)
      "path" (printf "%s/cel/cel-context" $prefix)
      "title" "CEL Expression Context"
      "weight" 10
    ) }}
  {{ end }}

{{ end }}
